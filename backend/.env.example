# ===========================
# EasyGit Backend
# ===========================

# --- LLM (Google AI Studio or Vertex AI) ---
# OPTION 1: Google AI Studio API Key (Easiest for deployment)
# Get from: https://aistudio.google.com
GOOGLE_API_KEY=your-api-key

# OPTION 2: Vertex AI (Requires Google Cloud setup)
# Authentication: gcloud auth application-default login
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1
LLM_MODEL=gemini-3-flash-preview

# --- GitHub ---
GITHUB_TOKEN=your-github-token

# --- MongoDB ---
# Local:   mongodb://localhost:27017
# Atlas:   mongodb+srv://user:pass@cluster.mongodb.net/
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=EasyGit

# --- Qdrant Vector DB ---
# Local:   localhost
# Cloud:   https://your-cluster-id.aws.cloud.qdrant.io
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API=                # API key for Qdrant Cloud (leave empty for local)

# --- App ---
APP_HOST=0.0.0.0
APP_PORT=8000
CORS_ORIGINS=http://localhost:3000

# --- Embedding (Google Premium) ---
# text-embedding-005: Google's premium model (768 dims)
# gemini-embedding-2: Google's new multimodal embedding model (3072 dims)
EMBEDDING_MODEL=gemini-embedding-2
EMBEDDING_DIMENSION=3072
